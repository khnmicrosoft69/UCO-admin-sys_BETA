---
interface Props {
  title: string;
  value: string;
  change: string;
  sparklineColor: string;
}

const { title, value, change, sparklineColor } = Astro.props;
---

<div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 font-sans">
  <div class="flex justify-between items-start mb-4">
    <p class="text-sm font-medium text-gray-600">{title}</p>
    <div class={`w-20 h-8 rounded-full ${sparklineColor} opacity-20`}></div> </div>
  
  <p class="text-4xl font-bold text-gray-900 mb-1">{value}</p>
  <p class="text-sm text-gray-500">Since last week <span class="font-medium text-green-600 bg-green-100 px-2 py-0.5 rounded-full">{change}</span></p>
</div>