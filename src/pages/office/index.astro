---
import ResponsiveLayout from '@/components/react/ui/ResponsiveLayout.jsx';
import DashboardContent from '@/components/react/interactive/DashboardContent.jsx';
import '@/assets/global.css';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Office Dashboard | UCO Admin</title>
</head>
<body class="bg-slate-50">
  <ResponsiveLayout client:load>
    <div class="p-4 md:p-8 pb-0 max-w-[1600px] mx-auto">
        <div class="flex items-center gap-4 mb-4">
            <a href="/dashboard/departments" class="text-xs font-bold text-slate-500 hover:text-indigo-600 uppercase tracking-widest flex items-center gap-1 transition-colors">
                <span class="w-6 h-6 flex items-center justify-center bg-white rounded-lg shadow-sm border border-slate-300">←</span>
                Back to Departments
            </a>
        </div>
        <h1 id="office-title-header" class="text-2xl md:text-3xl font-black text-slate-900 uppercase tracking-tight">Office Dashboard</h1>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-[0.2em] mt-1">Specialized Performance Metrics</p>
    </div>
    
    <DashboardContent client:load /> 
  </ResponsiveLayout>

  <script>
    const urlParams = new URLSearchParams(window.location.search);
    const officeName = urlParams.get('office') || urlParams.get('name');
    
    if (officeName) {
        document.getElementById('office-title-header').innerText = officeName;
        document.title = `${officeName} Dashboard | UCO Admin`;
    } else {
        window.location.href = '/departments';
    }
  </script>
</body>
</html>
