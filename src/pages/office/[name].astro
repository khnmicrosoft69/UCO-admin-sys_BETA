---
import ResponsiveLayout from '@/components/react/ui/ResponsiveLayout.jsx';
import DashboardContent from '@/components/react/interactive/DashboardContent.jsx';
import '@/assets/global.css';

const { name } = Astro.params;
const officeName = decodeURIComponent(name || '').replace(/_/g, ' ');

export function getStaticPaths() {
  return [];
}
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{officeName} Dashboard | UCO Admin</title>
</head>
<body class="bg-slate-200">
  <ResponsiveLayout client:only="react">
    <div class="p-4 md:p-8 pb-0 max-w-[1600px] mx-auto">
        <div class="flex items-center gap-4 mb-4">
            <a href="/dashboard/departments" class="text-xs font-bold text-slate-500 hover:text-indigo-600 uppercase tracking-widest flex items-center gap-1">
                <span>←</span> Back to Departments
            </a>
        </div>
        <h1 class="text-2xl md:text-3xl font-black text-slate-900 uppercase tracking-tight">{officeName}</h1>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-[0.2em] mt-1">Specialized Office Performance Dashboard</p>
    </div>
    <DashboardContent client:only="react" officeName={officeName} /> 
  </ResponsiveLayout>
</body>
</html>
